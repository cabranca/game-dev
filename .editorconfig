# EditorConfig helps maintain consistent coding styles across editors

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,hpp,c}]
indent_style = space
indent_size = 4
max_line_length = 120
tab_width = 4
# Visual Studio respeta estas si no hay clang-format para el archivo
# VS Code también, y algunos linters las usan.

[*.{bat,sh}]
indent_style = tab
